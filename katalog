<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Quinsah Collection - Premium Store</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #e5e7eb; }
        [v-cloak] { display: none !important; }
        .app-container {
            max-w: 480px; margin: 0 auto; background-color: #ffffff;
            min-height: 100vh; position: relative; box-shadow: 0 0 40px rgba(0,0,0,0.05);
            overflow-x: hidden;
        }
        /* Hide scrollbar for clean look */
        ::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="text-zinc-800 antialiased">

    <div id="app" v-cloak class="app-container">
        
        <!-- HEADER -->
        <header class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-zinc-100 px-4 py-3 flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-[10px] text-zinc-400 font-semibold tracking-widest uppercase">Quinsah</span>
                <span class="text-lg font-bold text-zinc-900 tracking-tight">Koleksi Eksklusif</span>
            </div>
            
            <button @click="isCartOpen = true" class="relative p-2 bg-zinc-50 rounded-full border border-zinc-100 text-zinc-700 hover:bg-zinc-100 transition-colors">
                <i class="fa-solid fa-bag-shopping"></i>
                <span v-if="cartCount > 0" class="absolute -top-1 -right-1 bg-red-700 text-white text-[10px] font-bold w-4 h-4 flex items-center justify-center rounded-full border border-white">
                    {{ cartCount }}
                </span>
            </button>
        </header>

        <!-- KONTEN UTAMA -->
        <main class="px-4 py-5 pb-24">
            
            <!-- SEARCH BAR -->
            <div class="relative mb-4">
                <i class="fa-solid fa-search absolute left-4 top-3.5 text-zinc-400 text-sm"></i>
                <input type="text" v-model="searchQuery" placeholder="Cari koleksi fashion..." class="w-full pl-10 pr-4 py-3 bg-zinc-50 border border-zinc-200 rounded-xl focus:outline-none focus:border-zinc-400 text-sm transition-all">
            </div>
            
            <!-- DROPDOWN KATEGORI MODERN -->
            <div class="mb-6 relative">
                <button @click="isCategoryDropdownOpen = !isCategoryDropdownOpen" class="w-full bg-white border border-zinc-200 rounded-xl px-4 py-3 flex items-center justify-between shadow-sm active:bg-zinc-50 transition-colors">
                    <div class="flex items-center gap-2">
                        <i class="fa-solid fa-layer-group text-zinc-400 text-sm"></i>
                        <span class="text-sm font-medium text-zinc-700">
                            {{ selectedCategory === '' ? 'Semua Kategori' : selectedCategory }}
                        </span>
                    </div>
                    <i class="fa-solid fa-chevron-down text-zinc-400 text-xs transition-transform" :class="{'rotate-180': isCategoryDropdownOpen}"></i>
                </button>

                <!-- Panel Dropdown Kategori -->
                <div v-if="isCategoryDropdownOpen" class="absolute top-full left-0 right-0 mt-2 bg-white border border-zinc-100 rounded-xl shadow-lg z-20 overflow-hidden">
                    <button @click="selectCategory('')" class="w-full text-left px-4 py-3 text-sm font-medium text-zinc-800 hover:bg-zinc-50 border-b border-zinc-50">
                        Semua Kategori
                    </button>
                    <!-- Looping Kategori Induk -->
                    <div v-for="(cat, idx) in categories" :key="cat.id" class="border-b border-zinc-50 last:border-0">
                        <button @click="selectCategory(cat.name || cat.nama)" class="w-full text-left px-4 py-3 text-sm text-zinc-700 hover:bg-zinc-50 flex items-center justify-between">
                            {{ cat.name || cat.nama }}
                            <!-- Jika ada sub kategori (simulasi indikator) -->
                            <i v-if="cat.subcategories" class="fa-solid fa-chevron-right text-[10px] text-zinc-300"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- GRID PRODUK -->
            <div v-if="isLoading" class="text-center py-10">
                <i class="fa-solid fa-spinner animate-spin text-xl text-zinc-400 mb-2"></i>
            </div>

            <div v-else-if="filteredProducts.length === 0" class="text-center py-12 bg-zinc-50 rounded-2xl border border-zinc-100">
                <p class="text-sm font-medium text-zinc-600">Produk tidak ditemukan</p>
            </div>

            <div v-else class="grid grid-cols-2 gap-3 w-full">
                <!-- KARTU PRODUK SEKARANG KLIKABLE UNTUK BUKA DETAIL -->
                <div v-for="prod in filteredProducts" :key="prod.id" @click="openProductDetail(prod)" class="bg-white rounded-xl border border-zinc-100 shadow-sm overflow-hidden flex flex-col relative cursor-pointer active:scale-[0.98] transition-transform">
                    <div class="aspect-[3/4] bg-zinc-100 w-full relative">
                        <img :src="prod.displayImage" @error="handleImageError(prod)" :alt="prod.name" class="w-full h-full object-cover">
                    </div>
                    
                    <div class="p-3 flex flex-col flex-1 justify-between bg-white">
                        <h3 class="text-xs font-semibold text-zinc-800 line-clamp-2 leading-tight mb-2">{{ prod.name }}</h3>
                        <span class="text-[13px] font-bold text-zinc-900">Rp{{ formatRupiah(prod.price) }}</span>
                    </div>
                </div>
            </div>
        </main>

        <!-- ========================================== -->
        <!-- BOTTOM SHEET: DETAIL PRODUK & VARIAN -->
        <!-- ========================================== -->
        <div v-if="selectedProduct" class="fixed inset-0 z-50 flex items-end justify-center">
            <!-- Overlay Gelap -->
            <div class="absolute inset-0 bg-zinc-900/60 backdrop-blur-sm transition-opacity" @click="closeProductDetail"></div>
            
            <!-- Panel Detail -->
            <div class="relative w-full max-w-[480px] bg-white rounded-t-3xl h-[85vh] flex flex-col shadow-2xl animate-slide-up">
                
                <!-- Tombol Close -->
                <button @click="closeProductDetail" class="absolute top-4 right-4 w-8 h-8 bg-black/20 backdrop-blur-md rounded-full text-white flex items-center justify-center z-10">
                    <i class="fa-solid fa-xmark text-sm"></i>
                </button>

                <div class="flex-1 overflow-y-auto pb-24">
                    <!-- Foto Besar -->
                    <div class="w-full aspect-[4/5] bg-zinc-100">
                        <img :src="selectedProduct.displayImage" class="w-full h-full object-cover">
                    </div>
                    
                    <!-- Informasi Utama -->
                    <div class="p-5 border-b border-zinc-100">
                        <h2 class="text-lg font-bold text-zinc-900 leading-tight mb-2">{{ selectedProduct.name }}</h2>
                        <p class="text-xl font-extrabold text-red-700">Rp{{ formatRupiah(selectedProduct.price) }}</p>
                        
                        <!-- Status Stok -->
                        <div class="mt-3 inline-flex items-center gap-1.5 px-2 py-1 bg-green-50 text-green-700 rounded text-[10px] font-bold uppercase tracking-wide">
                            <i class="fa-solid fa-check-circle"></i> Stok Tersedia ({{ selectedProduct.stock }})
                        </div>
                    </div>

                    <!-- Pilihan Varian (Warna / Ukuran) -->
                    <div class="p-5 border-b border-zinc-100">
                        <h3 class="text-xs font-bold text-zinc-800 uppercase tracking-widest mb-3">Pilih Varian</h3>
                        
                        <div v-if="selectedProduct.variants && selectedProduct.variants.length > 0" class="flex flex-wrap gap-2">
                            <button 
                                v-for="(v, index) in selectedProduct.variants" 
                                :key="index"
                                @click="activeVariant = v"
                                :class="activeVariant === v ? 'bg-zinc-900 text-white border-zinc-900' : 'bg-white text-zinc-600 border-zinc-200'"
                                class="px-4 py-2 rounded-lg border text-sm font-medium transition-all"
                            >
                                {{ v }}
                            </button>
                        </div>
                        <div v-else class="text-xs text-zinc-500 italic">
                            Produk ini tidak memiliki varian ukuran/warna khusus.
                        </div>
                    </div>

                    <!-- Deskripsi Produk -->
                    <div class="p-5">
                        <h3 class="text-xs font-bold text-zinc-800 uppercase tracking-widest mb-3">Deskripsi Produk</h3>
                        <p class="text-sm text-zinc-600 leading-relaxed whitespace-pre-line">
                            {{ selectedProduct.description || selectedProduct.deskripsi || 'Tidak ada deskripsi detail untuk produk ini.' }}
                        </p>
                    </div>
                </div>

                <!-- Footer CTA Beli -->
                <div class="absolute bottom-0 left-0 right-0 p-4 bg-white border-t border-zinc-100 shadow-[0_-10px_20px_rgba(0,0,0,0.05)]">
                    <button @click="addToCartFromDetail" class="w-full bg-zinc-900 text-white py-3.5 rounded-xl font-bold text-sm tracking-wide flex items-center justify-center gap-2 hover:bg-zinc-800 active:scale-95 transition-all">
                        <i class="fa-solid fa-bag-shopping"></i> Tambah Ke Keranjang
                    </button>
                </div>
            </div>
        </div>

        <!-- ========================================== -->
        <!-- SLIDE KANTONG BELANJA (CART) -->
        <!-- ========================================== -->
        <div v-if="isCartOpen" class="fixed inset-0 z-50 flex justify-center">
            <div class="absolute inset-0 bg-zinc-900/60 backdrop-blur-sm" @click="isCartOpen = false"></div>
            
            <div class="relative w-full max-w-[480px] bg-white mt-auto rounded-t-3xl h-[80vh] flex flex-col shadow-2xl animate-slide-up">
                <div class="p-4 border-b border-zinc-100 flex items-center justify-between">
                    <h2 class="font-bold text-sm text-zinc-800"><i class="fa-solid fa-bag-shopping text-red-700"></i> Keranjang</h2>
                    <button @click="isCartOpen = false" class="w-8 h-8 bg-zinc-100 rounded-full flex items-center justify-center"><i class="fa-solid fa-xmark"></i></button>
                </div>

                <div class="flex-1 overflow-y-auto p-4 space-y-3 bg-zinc-50">
                    <div v-if="cart.length === 0" class="text-center py-20 text-zinc-400">
                        <p class="text-xs font-medium">Keranjang masih kosong</p>
                    </div>
                    
                    <div v-for="(item, idx) in cart" :key="idx" class="flex gap-3 bg-white p-3 rounded-xl border border-zinc-100 shadow-sm">
                        <img :src="item.displayImage" class="w-16 h-20 object-cover rounded-lg">
                        <div class="flex-1 flex flex-col justify-between py-1">
                            <div>
                                <h4 class="text-xs font-semibold text-zinc-800 line-clamp-1">{{ item.name }}</h4>
                                <!-- TAMPILAN VARIAN DI KERANJANG -->
                                <span v-if="item.variant" class="text-[10px] text-zinc-500 mt-0.5 block">Varian: {{ item.variant }}</span>
                            </div>
                            <div class="flex items-center justify-between mt-2">
                                <span class="text-sm font-bold text-red-700">Rp{{ formatRupiah(item.price) }}</span>
                                <div class="flex items-center border border-zinc-200 rounded-md">
                                    <button @click="updateQty(idx, -1)" class="w-6 h-6 flex items-center justify-center text-zinc-600 hover:bg-zinc-100">-</button>
                                    <span class="text-xs font-semibold w-6 text-center">{{ item.qty }}</span>
                                    <button @click="updateQty(idx, 1)" class="w-6 h-6 flex items-center justify-center text-zinc-600 hover:bg-zinc-100">+</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="p-4 border-t border-zinc-100 bg-white">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-xs text-zinc-500 font-medium">Subtotal</span>
                        <span class="text-lg font-bold text-zinc-900">Rp {{ formatRupiah(cartTotal) }}</span>
                    </div>
                    <button @click="checkoutWhatsApp" class="w-full bg-zinc-900 text-white py-3.5 rounded-xl font-bold text-xs uppercase flex items-center justify-center gap-2 hover:bg-zinc-800 active:scale-95 transition-all">
                        <i class="fa-brands fa-whatsapp text-green-400 text-lg"></i> Checkout WhatsApp
                    </button>
                </div>
            </div>
        </div>

    </div>

    <!-- SCRIPT VUE & FIREBASE -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getFirestore, collection, getDocs } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";
        import { createApp } from "https://unpkg.com/vue@3/dist/vue.esm-browser.js";

        const firebaseConfig = { 
            apiKey: "AIzaSyBvwkhhUoFOMoKTPL4TWTCJxlx0AXoA3t4", 
            authDomain: "quinsahcollection-36926.firebaseapp.com", 
            projectId: "quinsahcollection-36926" 
        };
        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const DEFAULT_IMAGE = 'https://placehold.co/400x533/f4f4f5/a1a1aa?text=Quinsah';

        createApp({
            data() {
                return {
                    whatsappNumber: "628123456789", 
                    products: [],
                    categories: [],
                    cart: [],
                    searchQuery: '',
                    selectedCategory: '',
                    isCategoryDropdownOpen: false,
                    isLoading: true,
                    isCartOpen: false,
                    
                    // State untuk Detail Produk
                    selectedProduct: null,
                    activeVariant: null,
                }
            },
            computed: {
                filteredProducts() {
                    return this.products.filter(p => {
                        const matchesSearch = p.name.toLowerCase().includes(this.searchQuery.toLowerCase());
                        const matchesCategory = !this.selectedCategory || p.category === this.selectedCategory;
                        return matchesSearch && matchesCategory && p.stock > 0;
                    });
                },
                cartCount() {
                    return this.cart.reduce((sum, item) => sum + item.qty, 0);
                },
                cartTotal() {
                    return this.cart.reduce((sum, item) => sum + (item.price * item.qty), 0);
                }
            },
            async mounted() {
                await this.fetchData();
            },
            methods: {
                async fetchData() {
                    try {
                        this.isLoading = true;
                        const catSnap = await getDocs(collection(db, "categories"));
                        this.categories = catSnap.docs.map(doc => ({ id: doc.id, ...doc.data() }));

                        const prodSnap = await getDocs(collection(db, "products"));
                        this.products = prodSnap.docs.map(doc => {
                            const data = doc.data();
                            
                            let currentStock = data.stock ?? data.stok ?? data.qty ?? 1;
                            const rawImage = data.imageUrl || data.foto || data.image || data.gambar || '';
                            
                            // Deteksi Varian dari Firebase (Cek apakah ada array varian)
                            // Jika tidak ada, saya berikan dummy ['All Size'] agar pembeli tetap bisa checkout
                            let productVariants = data.varian || data.variants || data.ukuran || [];
                            if (!Array.isArray(productVariants) || productVariants.length === 0) {
                                productVariants = ['All Size']; // Default fallback
                            }

                            return {
                                id: doc.id,
                                ...data,
                                name: data.name || data.nama || 'Produk Fashion',
                                price: Number(data.hargaJual || data.price || data.harga || 0),
                                stock: Number(currentStock),
                                displayImage: rawImage ? rawImage : DEFAULT_IMAGE,
                                description: data.deskripsi || data.description || '',
                                variants: productVariants
                            };
                        });
                    } catch (error) {
                        console.error("Error:", error);
                    } finally {
                        this.isLoading = false;
                    }
                },
                
                // === MANAJEMEN DROPDOWN & DETAIL ===
                selectCategory(catName) {
                    this.selectedCategory = catName;
                    this.isCategoryDropdownOpen = false;
                },
                openProductDetail(product) {
                    this.selectedProduct = product;
                    // Otomatis pilih varian pertama saat dibuka
                    this.activeVariant = product.variants && product.variants.length > 0 ? product.variants[0] : null;
                },
                closeProductDetail() {
                    this.selectedProduct = null;
                    this.activeVariant = null;
                },

                // === KERANJANG ===
                addToCartFromDetail() {
                    if (!this.selectedProduct) return;
                    
                    // Pastikan pelanggan sudah memilih varian jika produk memiliki varian
                    if (this.selectedProduct.variants && this.selectedProduct.variants.length > 0 && !this.activeVariant) {
                        alert("Mohon pilih varian (ukuran/warna) terlebih dahulu.");
                        return;
                    }

                    // Buat ID Unik Keranjang (Gabungan ID Produk + Varian)
                    // Agar "Baju Merah S" dan "Baju Merah L" tidak tergabung jadi 1 item
                    const cartItemId = this.selectedProduct.id + '-' + (this.activeVariant || 'default');
                    
                    const existingItem = this.cart.find(item => item.cartItemId === cartItemId);
                    
                    if (existingItem) {
                        if (existingItem.qty < this.selectedProduct.stock) {
                            existingItem.qty++;
                            alert("Jumlah produk ditambahkan ke keranjang.");
                        } else {
                            alert("Batas maksimal stok tercapai.");
                        }
                    } else {
                        this.cart.push({
                            cartItemId: cartItemId,
                            id: this.selectedProduct.id,
                            name: this.selectedProduct.name,
                            price: this.selectedProduct.price,
                            displayImage: this.selectedProduct.displayImage,
                            variant: this.activeVariant,
                            qty: 1
                        });
                        alert("Berhasil dimasukkan ke keranjang!");
                    }
                    this.closeProductDetail();
                },
                updateQty(index, change) {
                    const item = this.cart[index];
                    const newQty = item.qty + change;
                    if (newQty <= 0) {
                        this.cart.splice(index, 1);
                    } else {
                        item.qty = newQty;
                    }
                },
                handleImageError(product) {
                    product.displayImage = DEFAULT_IMAGE;
                },
                formatRupiah(val) {
                    return new Intl.NumberFormat('id-ID').format(val || 0);
                },
                checkoutWhatsApp() {
                    if (this.cart.length === 0) return;
                    
                    let text = `*ORDER BARU - QUINSAH COLLECTION*\n`;
                    text += `----------------------------------\n\n`;
                    
                    this.cart.forEach((item, index) => {
                        text += `${index + 1}. *${item.name}*\n`;
                        if(item.variant && item.variant !== 'All Size') {
                            text += `   Varian: ${item.variant}\n`;
                        }
                        text += `   Jumlah: ${item.qty} pcs\n`;
                        text += `   Harga: Rp${this.formatRupiah(item.price)}/pcs\n\n`;
                    });
                    
                    text += `----------------------------------\n`;
                    text += `*TOTAL BELANJA: Rp${this.formatRupiah(this.cartTotal)}*\n\n`;
                    text += `Halo admin, saya mau order produk di atas ya.`;
                    
                    const waUrl = `https://api.whatsapp.com/send?phone=${this.whatsappNumber}&text=${encodeURIComponent(text)}`;
                    window.open(waUrl, '_blank');
                }
            }
        }).mount('#app');
    </script>

    <style>
        @keyframes slide-up {
            from { transform: translateY(100%); opacity: 0.5; }
            to { transform: translateY(0); opacity: 1; }
        }
        .animate-slide-up {
            animation: slide-up 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
    </style>
</body>
</html>
